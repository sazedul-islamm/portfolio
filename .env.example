GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=your-github-personal-access-token
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
ADMIN_PASSWORD=change-me-before-deploy
ADMIN_SESSION_SECRET=generate-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

ADMIN_EMAIL=your-email@example.com
RESEND_API_KEY=your-resend-api-key

# Cloudflare API access for D1 queries from Next.js route handlers.
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
D1_DATABASE_ID=your-d1-database-id

# Cloudflare R2 metadata. The bucket is bound in `wrangler.toml` as `ASSETS`.
# Keep the bucket name here so local/server-side code can stay aligned with the deployment config.
R2_BUCKET_NAME=portfolio-assets

# Optional if you later switch to S3-compatible R2 uploads from Node.js.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Cloudflare D1 and R2 are configured in `wrangler.toml` or the Cloudflare dashboard.
# Keep database IDs, bucket names, and other provider-specific bindings out of the browser.
# If you need local-only values, add them here and load them from server-side code only.